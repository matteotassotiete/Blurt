# Transcription (always Groq Whisper)
GROQ_API_KEY=your_groq_api_key_here

# Routing — Claude when ANTHROPIC_API_KEY is set (recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: force provider (anthropic | groq). Default: anthropic if key set, else groq
# ROUTING_PROVIDER=anthropic

# Optional: override routing model
# Anthropic default: claude-haiku-4-5-20251001
# Groq default: llama-3.3-70b-versatile
# ROUTING_MODEL=claude-3-5-haiku-latest
